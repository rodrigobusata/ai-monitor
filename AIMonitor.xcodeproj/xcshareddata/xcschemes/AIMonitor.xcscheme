               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "0FEECB79064F69FDD78B9045"
                     BuildableName = "AIMonitor.app"
                     BlueprintName = "AIMonitor"
